[Unit]
Description=Positive News Preparer (one batch)
# The router serves the model; the crawler DB must exist before we read it.
After=network-online.target model-router-mcp.service
Wants=network-online.target

[Service]
Type=oneshot
User=newsevaluator
Group=newsevaluator
SupplementaryGroups=newscrawler
# Group access to the crawler DB sidecar files (-wal/-shm) per the contract.
UMask=0007
# Defaults; /etc file overrides them.
Environment=PREP_BATCH=5
EnvironmentFile=/etc/news-evaluator/news-evaluator.env
ExecStart=/usr/bin/python3 /opt/news-evaluator/preparer.py --limit ${PREP_BATCH}
NoNewPrivileges=true
# No PrivateTmp: writes go to /var/lib/news-evaluator, owned by this user.
