# Positive News Evaluator config.
# Live copy: /etc/news-evaluator/news-evaluator.env (root:newsevaluator, 0640 - it holds a token).
# Edits apply on the next timer run; no restart, no code change.

# Bearer token of model-router-mcp (AUTH_TOKEN from /opt/model-router-mcp/.env).
ROUTER_AUTH_TOKEN=fill-me

ROUTER_MCP_URL=http://127.0.0.1:8088/mcp
NEWS_DB_PATH=/var/lib/newscrawler/newscrawler.sqlite3
SELECTOR_NAME=news-evaluator

# Model routing. EVALUATOR_MODEL pins one model; leave it EMPTY to let the
# router pick by EVALUATOR_PROVIDER / EVALUATOR_TIER hints (empty hints are
# not sent at all). The model that actually answered is recorded in each
# event's selector_version either way.
EVALUATOR_PROVIDER=deepseek
EVALUATOR_MODEL=deepseek-chat
EVALUATOR_TIER=

# News per timer run.
EVALUATOR_BATCH=25

# --- Preparer (turns selected news into HTML pages) ---
# Evaluator-owned storage, separate from the crawler DB (contract).
EVALUATOR_DB_PATH=/var/lib/news-evaluator/evaluator.sqlite3
MEDIA_DIR=/var/lib/news-evaluator/media
PAGES_DIR=/var/lib/news-evaluator/pages
PREPARER_USER_AGENT=PositiveNewsEvaluator/0.1 (+mailto:mail@wildcar.ru)
# Selected news prepared per preparer timer run.
PREP_BATCH=5

# --- Publisher (posts prepared news to the platforms) ---
# Prepared news published per publisher timer run. Keep small so posts trickle
# into the public channel/site rather than flooding it; raise to drain a backlog.
PUB_BATCH=1
# A platform turns ON only when its secrets are set here; leave blank to skip it.
# The publisher timer runs harmlessly (posts nothing) until at least one is set.

# Telegram channel @posinus. Token from @BotFather (the same bot used before).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=-1003795927410
TELEGRAM_CHANNEL_USERNAME=posinus

# Site wildcar.ru (Эгея). Login is 'wildcar', password is the Эгея account password.
EGEYA_BASE_URL=https://wildcar.ru
EGEYA_LOGIN=wildcar
EGEYA_PASSWORD=
EGEYA_TAGS=добрые новости

# VK community wall. NOTE: photo upload needs a USER token of a group admin with
# scope photos,wall,groups (a community token fails getWallUploadServer, error 27).
# VK_GROUP_ID is the numeric community id (positive number).
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199
